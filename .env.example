# ============================================================
# 환경변수 설정 예시 — 실제 값은 절대 커밋하지 마세요!
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 입력하세요.
# .env 파일은 .gitignore에 포함되어 있어야 합니다.
# ============================================================

# 데이터베이스
DB_USERNAME=your_db_username
DB_PASSWORD=your_strong_db_password_here   # 최소 12자, 특수문자 포함 권장

# JWT 시크릿 (최소 32바이트/256비트 이상)
# 생성 예시: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_32_to_generate

# SOLAPI SMS
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SOLAPI_SENDER=01012345678  # 발신 번호

# Google OAuth2  (https://console.cloud.google.com → 사용자 인증 정보)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/oauth/google

# Kakao OAuth2  (https://developers.kakao.com → 내 애플리케이션 → 앱 키)
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:8080/auth/oauth/kakao

# WebSocket CORS 허용 오리진 (쉼표 구분, 프로덕션에서 반드시 설정)
# WEBSOCKET_ALLOWED_ORIGINS=https://your-frontend-domain.com
